generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String

  bids     Bid[]
  submissions   BidSubmission[]
}

model Bid {
  id          Int      @id @default(autoincrement())
  title       String
  origin      String
  destination String
  price       Float
  status      String   @default("open")
  merchantId  Int
  createdAt   DateTime @default(now())

  merchant    User     @relation(fields: [merchantId], references: [id])
  submissions   BidSubmission[]
}

model BidSubmission {
  id             Int      @id @default(autoincrement())
  price          Float
  estimatedTime  Int
  transporterId  Int
  bidId          Int
  createdAt      DateTime @default(now())

  transporter    User     @relation(fields: [transporterId], references: [id])
  bid            Bid      @relation(fields: [bidId], references: [id])
}